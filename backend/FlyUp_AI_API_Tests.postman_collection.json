                  "});",
                  "",
                  "pm.test(\"Content-Type is event-stream\", function () {",
                  "    pm.response.to.have.header(\"Content-Type\");",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"text/event-stream\");",
                  "});"
