      "name": "1. Chatbot",
      "item": [
        {
          "name": "1.1 Standard Chat",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response time is acceptable (< 15s)\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(15000);",
                  "});",
                  "",
                  "pm.test(\"Response contains valid payload\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('response');",
                  "    pm.expect(jsonData).to.have.property('sessionId');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Khóa học React cơ bản là gì?\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chatbot",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "chatbot"
              ]
            }
          },
          "response": []
        },
        {
          "name": "1.2 Streaming Chat (SSE)",
          "event": [
