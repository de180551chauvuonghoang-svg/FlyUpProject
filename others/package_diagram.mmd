---
title: FlyUp Project — Package Architecture
---
graph TD

  subgraph BACKEND["⚙️ BACKEND · NodeJS + Express"]
    direction TB

    subgraph BE_ROOT["Root"]
      PRISMA["prisma/"]
      SCRIPTS["scripts/"]
    end

    subgraph BE_SRC["src/"]
      direction TB

      subgraph BE_MODULES["modules/ · Feature Vertical Slices"]
        direction TB
        BE_AUTH["auth/\nroutes · controller · service · validation"]
        BE_USER["user/\nroutes · controller · service"]
        BE_COURSE["course/\nroutes · controller · service"]
        BE_CHECKOUT["checkout/\nroutes · controller · service"]
        BE_PAYMENT["payment/\nroutes · controller · service"]
        BE_TRANSACTION["transaction/\nroutes · controller · service"]
        BE_WISHLIST["wishlist/\nroutes · controller · service"]
        BE_COMMENT["comment/\nroutes · controller · service"]
        BE_CHATBOT["chatbot/\nroutes · controller · service"]
      end

      subgraph BE_SHARED["shared/ · Cross-Cutting Concerns"]
        BE_MW["middleware/\nauth · rateLimit · validation"]
        BE_UTILS["utils/\njwt · formatters · helpers"]
        BE_WORKERS["workers/\nemail.worker"]
      end

      subgraph BE_INFRA["infrastructure/ · External Adapters"]
        BE_DB["database/\nprisma.client"]
        BE_CACHE["cache/\nin-memory adapter"]
        BE_QUEUE["queue/\njob producer"]
        BE_EMAIL["email/\nSMTP transport"]
        BE_EXT["external/\nsupabase · 3rd-party"]
      end

      BE_CONFIG["config/\nApp constants · Swagger · Env"]
    end
  end

  subgraph FRONTEND["🖥️ FRONTEND · React + Vite"]
    direction TB

    subgraph FE_SRC["src/"]
      direction TB

      FE_APP["app/\nRouter · Provider tree · Root entry"]

      subgraph FE_FEATURES["features/ · Domain Feature Slices"]
        direction TB
        FE_AUTH["auth/\npages · api · store · hooks"]
        FE_COURSE["course/\npages · components · api · hooks"]
        FE_CHECKOUT["checkout/\npages · api · store · hooks"]
        FE_USER["user/\npages · components · api"]
        FE_CHATBOT["chatbot/\ncomponents · api"]
        FE_HOME["home/\npages · components"]
      end

      subgraph FE_SHARED["shared/ · Reusable Across ≥ 2 Features"]
        FE_COMP["components/\nHeader · Footer · Reviews · ShareModal"]
        FE_HOOKS["hooks/\nuseCounter · useScrollAnimation"]
        FE_UTILS_FE["utils/\nformatters · pure helpers"]
      end

      subgraph FE_CORE["core/"]
        FE_API["api/\nAxios base instance · Interceptors · Auth headers"]
      end

      FE_LAYOUTS["layouts/\nMainLayout · AuthLayout"]
      FE_CONFIG["config/\nRoute constants · Env keys"]
    end
  end

  %% ── Backend dependency direction ──
  BE_MODULES --> BE_SHARED
  BE_SHARED  --> BE_INFRA
  BE_INFRA   --> BE_CONFIG

  %% ── Frontend dependency direction ──
  FE_APP      --> FE_FEATURES
  FE_APP      --> FE_LAYOUTS
  FE_FEATURES --> FE_SHARED
  FE_FEATURES --> FE_CORE
  FE_LAYOUTS  --> FE_SHARED

  %% ── HTTP boundary ──
  FE_CORE -. "HTTP REST" .-> BE_MODULES

  %% ── Styles ──
  classDef moduleBox  fill:#0d1f44,stroke:#3b82f6,color:#93c5fd
  classDef sharedBox  fill:#1e0d4e,stroke:#8b5cf6,color:#c4b5fd
  classDef infraBox   fill:#2a0d00,stroke:#f97316,color:#fdba74
  classDef configBox  fill:#111827,stroke:#4b5563,color:#6b7280
  classDef featureBox fill:#011c0e,stroke:#059669,color:#34d399
  classDef coreBox    fill:#150c00,stroke:#d97706,color:#fbbf24
  classDef layoutBox  fill:#031a11,stroke:#059669,color:#6ee7b7
  classDef rootBox    fill:#0f1f35,stroke:#334155,color:#4b6280

  class BE_AUTH,BE_USER,BE_COURSE,BE_CHECKOUT,BE_PAYMENT,BE_TRANSACTION,BE_WISHLIST,BE_COMMENT,BE_CHATBOT moduleBox
  class BE_MW,BE_UTILS,BE_WORKERS sharedBox
  class BE_DB,BE_CACHE,BE_QUEUE,BE_EMAIL,BE_EXT infraBox
  class BE_CONFIG,FE_CONFIG configBox
  class FE_AUTH,FE_COURSE,FE_CHECKOUT,FE_USER,FE_CHATBOT,FE_HOME featureBox
  class FE_COMP,FE_HOOKS,FE_UTILS_FE sharedBox
  class FE_API coreBox
  class FE_LAYOUTS layoutBox
  class FE_APP configBox
  class PRISMA,SCRIPTS rootBox
